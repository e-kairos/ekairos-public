{
  "name": "@ekairos/dataset",
  "version": "1.22.0",
  "description": "Pulzar Dataset Tools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "file/scripts",
    "skill"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e-kairos/ekairos.git",
    "directory": "packages/dataset"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain.d.ts",
      "import": "./dist/domain.js",
      "default": "./dist/domain.js"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "import": "./dist/query/index.js",
      "default": "./dist/query/index.js"
    },
    "./file/scripts": {
      "default": "./dist/file/scripts"
    },
    "./file/scripts/*": {
      "default": "./dist/file/scripts/*"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-python-scripts.js",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run -c vitest.config.mts",
    "test:direct": "vitest run -c vitest.config.mts src/tests/dataset.builder.instant.test.ts",
    "test:tool": "vitest run -c vitest.config.mts src/tests/materializeDataset.tool.instant.test.ts",
    "test:ai-sdk:instant": "vitest run -c vitest.codex.config.mts src/tests/materializeDataset.ai-sdk.instant.test.ts"
  },
  "dependencies": {
    "@ekairos/domain": "workspace:*",
    "@ekairos/events": "workspace:*",
    "@ekairos/sandbox": "^1.22.0",
    "@instantdb/admin": "0.22.158",
    "@instantdb/core": "0.22.142",
    "ai": "^5.0.44",
    "ajv": "^8.17.1",
    "xmlbuilder2": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^2.0.42",
    "@ekairos/openai-reactor": "workspace:*",
    "@ekairos/tsconfig": "workspace:*",
    "@types/node": "^24.5.0",
    "dotenv": "^17.2.3",
    "typescript": "^5.9.2"
  }
}
