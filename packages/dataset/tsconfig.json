{
  "extends": "@ekairos/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2020", "DOM"],
    "paths": {
      "@ekairos/domain": ["../domain/dist/index.d.ts"],
      "@ekairos/domain/runtime": ["../domain/dist/runtime.d.ts"],
      "@ekairos/openai-reactor": ["../reactors/openai-reactor/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/*.test.ts", "**/tests/**", "src/__type_tests__"]
}
