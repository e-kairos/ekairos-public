{
  "name": "@ekairos/events",
  "version": "1.22.0",
  "description": "Ekairos Events - Context-first workflow runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e-kairos/ekairos.git",
    "directory": "packages/events"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./domain": {
      "types": "./dist/domain.d.ts",
      "import": "./dist/domain.js",
      "require": "./dist/domain.js",
      "default": "./dist/domain.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./reactor": {
      "types": "./dist/context.reactor.d.ts",
      "import": "./dist/context.reactor.js",
      "require": "./dist/context.reactor.js",
      "default": "./dist/context.reactor.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.js",
      "default": "./dist/mcp.js"
    },
    "./oidc": {
      "types": "./dist/oidc.d.ts",
      "import": "./dist/oidc.js",
      "require": "./dist/oidc.js",
      "default": "./dist/oidc.js"
    },
    "./codex": {
      "types": "./dist/codex.d.ts",
      "import": "./dist/codex.js",
      "require": "./dist/codex.js",
      "default": "./dist/codex.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./instant": {
      "types": "./dist/stores/instant.store.d.ts",
      "import": "./dist/stores/instant.store.js",
      "require": "./dist/stores/instant.store.js",
      "default": "./dist/stores/instant.store.js"
    }
  },
  "typesVersions": {
    "*": {
      "schema": [
        "dist/schema.d.ts"
      ],
      "domain": [
        "dist/domain.d.ts"
      ],
      "runtime": [
        "dist/runtime.d.ts"
      ],
      "reactor": [
        "dist/context.reactor.d.ts"
      ],
      "mcp": [
        "dist/mcp.d.ts"
      ],
      "oidc": [
        "dist/oidc.d.ts"
      ],
      "codex": [
        "dist/codex.d.ts"
      ],
      "react": [
        "dist/react.d.ts"
      ],
      "instant": [
        "dist/stores/instant.store.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run -c vitest.config.mts",
    "test:workflow": "vitest run -c vitest.workflow.config.mts",
    "pretest:ai-sdk-reactor": "pnpm --filter @ekairos/domain build",
    "test:ai-sdk-reactor": "vitest run -c vitest.config.mts src/tests/context.ai-sdk-reactor.instant.test.ts",
    "test:ai-sdk-reactor:real": "vitest run -c vitest.config.mts src/tests/context.ai-sdk-reactor.real.instant.test.ts",
    "pretest:scripted-reactor": "pnpm --filter @ekairos/domain build",
    "test:scripted-reactor": "vitest run -c vitest.config.mts src/tests/context.scripted-reactor.instant.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.52",
    "@ekairos/domain": "workspace:*",
    "@instantdb/admin": "0.22.158",
    "@instantdb/core": "0.22.142",
    "@vercel/mcp-adapter": "^1.0.0",
    "@vercel/sandbox": "^0.0.23",
    "ai": "^5.0.95",
    "ajv": "^8.17.1",
    "jose": "^6.1.3",
    "llamaindex": "^0.12.0",
    "partial-json": "^0.1.7",
    "react": "^19.2.0",
    "workflow": "5.0.0-beta.1",
    "xmlbuilder2": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ekairos/testing": "workspace:*",
    "@ekairos/tsconfig": "workspace:*",
    "@types/node": "^24.5.0",
    "@types/react": "^19.2.2",
    "@workflow/serde": "5.0.0-beta.0",
    "@workflow/vitest": "5.0.0-beta.1",
    "dotenv": "^17.2.3",
    "typescript": "^5.9.2",
    "vitest": "^4.0.8"
  }
}
