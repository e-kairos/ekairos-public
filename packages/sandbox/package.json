{
  "name": "@ekairos/sandbox",
  "version": "1.22.0",
  "description": "Pulzar Sandbox - Provider-agnostic sandbox helpers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e-kairos/ekairos.git",
    "directory": "packages/sandbox"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "require": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox.d.ts",
      "import": "./dist/sandbox.js",
      "require": "./dist/sandbox.js",
      "default": "./dist/sandbox.js"
    },
    "./public": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js",
      "require": "./dist/public.js",
      "default": "./dist/public.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js",
      "require": "./dist/actions.js",
      "default": "./dist/actions.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:workflow": "vitest run -c vitest.workflow.config.mts"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.134.0",
    "@ekairos/domain": "workspace:*",
    "@ekairos/events": "workspace:*",
    "@instantdb/admin": "0.22.158",
    "@instantdb/core": "0.22.158",
    "@vercel/sandbox": "2.0.0-beta.13",
    "@workflow/serde": "5.0.0-beta.0",
    "workflow": "5.0.0-beta.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ekairos/tsconfig": "workspace:*",
    "@types/node": "^24.5.0",
    "@workflow/vitest": "5.0.0-beta.1",
    "typescript": "^5.9.2"
  }
}
